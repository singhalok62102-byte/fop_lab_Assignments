#include <stdio.h>

// Function to swap without pointers (Call by Value)
void swapWithoutPointers(int a, int b) {
    int temp;
    temp = a;
    a = b;
    b = temp;
    printf("After swapping without pointers:\n");
    printf("a = %d b = %d\n", a, b);
}

// Function to swap with pointers (Call by Reference)
void swapWithPointers(int *x, int *y) {
    int temp;
    temp = *x;
    *x = *y;
    *y = temp;
    printf("After swapping with pointers:\n");
    printf("x = %d y = %d\n", *x, *y);
}

int main() {
    int a, b;
    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    // Call by Value
    swapWithoutPointers(a, b);

    // Call by Reference
    swapWithPointers(&a, &b);

    return 0;
}
