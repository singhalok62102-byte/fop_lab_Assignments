#include <stdio.h>

int main() {
    int n, i, j;
    float x, sum = 0, term, fact;

    scanf("%f", &x);
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        term = 1;
        fact = 1;

        for(j = 1; j <= (2*i+1); j++) {
            term *= x;
            fact *= j;
        }

        if(i % 2 == 0)
            sum += term / fact;
        else
            sum -= term / fact;
    }

    printf("Sum = %.6f", sum);

    return 0;
}
