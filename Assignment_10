#include <stdio.h>
int main() {
    int choice;
    double a, b, result = 1;
    int i;

    printf("1.Add 2.Sub 3.Mul 4.Div 5.Power 6.Factorial\n");
    scanf("%d", &choice);

    switch(choice) {
        case 1:
            scanf("%lf %lf", &a, &b);
            printf("Result = %.2lf", a + b);
            break;

        case 2:
            scanf("%lf %lf", &a, &b);
            printf("Result = %.2lf", a - b);
            break;

        case 3:
            scanf("%lf %lf", &a, &b);
            printf("Result = %.2lf", a * b);
            break;

        case 4:
            scanf("%lf %lf", &a, &b);
            if(b != 0)
                printf("Result = %.2lf", a / b);
            else
                printf("Cannot divide by zero");
            break;

        case 5:
            scanf("%lf %lf", &a, &b);
            result = 1;
            for(i = 1; i <= b; i++)
                result *= a;
            printf("Result = %.2lf", result);
            break;

        case 6:
            scanf("%lf", &a);
            result = 1;
            for(i = 1; i <= a; i++)
                result *= i;
            printf("Result = %.0lf", result);
            break;

        default:
            printf("Invalid choice");
    }

    return 0;
}
