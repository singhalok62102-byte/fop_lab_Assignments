#include <stdio.h>
int main() {
    int year;

    printf("Enter a year: ");
    scanf("%d", &year);

    if ((year % 400 == 0) || (year % 4 == 0 && year % 100 != 0)) {
        printf("%d is a Leap Year", year);
    } else {
        printf("%d is not a Leap Year", year);
    }

    return 0;
}



#This program checks if a year is a leap year or not. It takes a year as input from the user. Then it checks some conditions using division. If the year is divisible by 400 or divisible by 4 but not by 100, it is a leap year. Otherwise, it is not a leap year.
